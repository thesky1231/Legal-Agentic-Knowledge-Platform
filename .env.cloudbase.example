SERVICE_NAME=Legal Agentic Knowledge Platform
LOG_LEVEL=INFO
FRONTEND_DIST_DIR=/app/frontend/dist

BOOTSTRAP_KNOWLEDGE_PATHS=/app/examples/legal/law.pdf
BOOTSTRAP_SNAPSHOT_PATH=
BOOTSTRAP_TENANT_ID=demo
BOOTSTRAP_MODE=background

# First public demo: safest option
MODEL_PROVIDER=stub
RUN_STORE_BACKEND=memory

# If you have a real remote model API, switch to:
# MODEL_PROVIDER=openai_compatible
# MODEL_ENDPOINT_MODE=responses
# MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
# MODEL_API_KEY=your_key
# PRIMARY_MODEL_NAME=qwen3.6-plus

EMBEDDING_PROVIDER=hash
DEFAULT_TOP_K=8
EMBEDDING_BATCH_SIZE=32
VECTOR_STORE_BACKEND=memory
API_AUTH_ENABLED=false
