SERVICE_NAME=Agentic Knowledge Platform
LOG_LEVEL=INFO
EMBEDDING_DIMENSIONS=96
DEFAULT_TOP_K=4
CHUNK_SIZE=450
CHUNK_OVERLAP=80
GROUNDED_THRESHOLD=0.22
RATE_LIMIT_PER_MINUTE=60
CIRCUIT_BREAKER_FAILURES=2
CIRCUIT_BREAKER_RECOVERY_SECONDS=15
REQUEST_TIMEOUT_SECONDS=20

MODEL_PROVIDER=stub
MODEL_ENDPOINT_MODE=responses
MODEL_BASE_URL=https://api.openai.com
MODEL_API_KEY=
PRIMARY_MODEL_NAME=gpt-4.1-mini
PRIMARY_MODEL_LABEL=Primary Model
BACKUP_MODEL_LABEL=Fallback Model
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL_NAME=qwen2.5:7b
OLLAMA_TEMPERATURE=0
OLLAMA_KEEP_ALIVE=5m

EMBEDDING_PROVIDER=hash
EMBEDDING_BASE_URL=https://api.openai.com
EMBEDDING_API_KEY=
EMBEDDING_MODEL_NAME=text-embedding-3-small

VECTOR_STORE_BACKEND=memory
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=knowledge_chunks

RUN_STORE_BACKEND=memory
SQLITE_PATH=./data/agent_platform.db
BOOTSTRAP_KNOWLEDGE_PATHS=
BOOTSTRAP_TENANT_ID=demo

API_AUTH_ENABLED=false
API_KEYS=demo-key
